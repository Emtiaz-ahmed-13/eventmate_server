PORT=5001
NODE_ENV=production
JWT_SECRET=your_production_jwt_secret_change_this
JWT_EXPIRES_IN=1d
JWT_REFRESH_TOKEN_SECRET=your_production_refresh_secret_change_this
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

# Database - Neon Production Database
DATABASE_URL="your_production_database_url_here"

# Email Config - Production
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS="your_app_password_here"

# ImageKit Config
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint_here

# Stripe Config
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Base URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=https://your-backend-url.onrender.com