generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  role              Role      @default(USER)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  isVerified        Boolean   @default(false)
  verifyToken       String?
  verifyTokenExpiry DateTime?
  refreshToken      String?
  resetToken        String?
  resetTokenExpiry  DateTime?

  profile         Profile?
  hostedEvents    Event[]        @relation("HostedEvents")
  joinedEvents    Participant[]
  notifications   Notification[]
  reviewsMade     Review[]       @relation("Reviewer")
  reviewsReceived Review[]       @relation("HostReviews")
  Waitlist        Waitlist[]
  savedEvents     SavedEvent[]
  chatMessages    ChatMessage[]
  discussions     Discussion[]
  following       Follower[]     @relation("UserFollowers")
  followers       Follower[]     @relation("HostFollowers")

  @@map("users")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  type      String // e.g., "EVENT_JOIN", "EVENT_REMINDER"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  profileImage String?
  headerImage  String?
  bio          String?
  interests    String[]
  location     String?

  @@map("profiles")
}

model Event {
  id              String        @id @default(uuid())
  name            String
  type            String
  dateTime        DateTime
  location        String
  latitude        Float?
  longitude       Float?
  minParticipants Int
  maxParticipants Int
  description     String
  image           String?
  joiningFee      Float         @default(0)
  status          EventStatus   @default(OPEN)
  hostId          String
  host            User          @relation("HostedEvents", fields: [hostId], references: [id])
  participants    Participant[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cancelledAt     DateTime?
  Waitlist        Waitlist[]
  savedBy         SavedEvent[]
  reviews         Review[]
  approvalRequired Boolean @default(false)
  category        String?
  chatMessages    ChatMessage[]
  discussions     Discussion[]

  @@map("events")
}

model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("saved_events")
}

model Waitlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("waitlists")
}

model Participant {
  ticketId    String    @unique @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id])
  joinedAt    DateTime  @default(now())
  status      ParticipantStatus @default(APPROVED)
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?

  @@id([userId, eventId])
  @@map("participants")
}

model Review {
  id         String   @id @default(uuid())
  reviewerId String
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  hostId     String
  host       User     @relation("HostReviews", fields: [hostId], references: [id])
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@map("reviews")
}

model ChatMessage {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@map("chat_messages")
}

model Discussion {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  question  String
  answer    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("discussions")
}

model Follower {
  id         String   @id @default(uuid())
  followerId String
  follower   User     @relation("UserFollowers", fields: [followerId], references: [id])
  hostId     String
  host       User     @relation("HostFollowers", fields: [hostId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([followerId, hostId])
  @@map("followers")
}

enum Role {
  USER
  HOST
  ADMIN
}

enum EventStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}
enum ParticipantStatus {
  PENDING
  APPROVED
  REJECTED
}
